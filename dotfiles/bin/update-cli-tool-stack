#!/bin/zsh

set -euo pipefail

export CLI_TOOL_STACK_GENERATING=1

OUT_FILE="$HOME/CLI_TOOL_STACK.md"
TMP_FILE="${OUT_FILE}.tmp"

if ! command -v zsh >/dev/null 2>&1; then
  exit 1
fi

tool_version() {
  local cmd="$1"
  (
    "$cmd" --version 2>/dev/null |
      /usr/bin/head -n 1
  ) || (
    "$cmd" -V 2>/dev/null |
      /usr/bin/head -n 1
  ) || (
    "$cmd" version 2>/dev/null |
      /usr/bin/head -n 1
  ) || echo "installed"
}

tool_source() {
  local path="$1"

  case "$path" in
    /opt/homebrew/*) echo "Homebrew" ;;
    "$HOME/.bun/"*) echo "Bun installer" ;;
    "$HOME/.local/bin/"*) echo "User-local script" ;;
    /Applications/*.app/*) echo "App install" ;;
    *) echo "Other" ;;
  esac
}

display_path() {
  local path="$1"
  printf '%s\n' "${path/#$HOME/~}"
}

emit_tool_row() {
  local cmd="$1"
  local purpose="$2"
  local bin_path="" version="" source=""

  bin_path=$(command -v "$cmd" 2>/dev/null || true)
  [[ -n "$bin_path" ]] || return 0

  version=$(tool_version "$cmd")
  source=$(tool_source "$bin_path")
  bin_path=$(display_path "$bin_path")

  printf '| `%s` | %s | `%s` | %s | %s |\n' \
    "$cmd" "$version" "$bin_path" "$purpose" "$source"
}

emit_alias_rows() {
  CLI_TOOL_STACK_GENERATING=1 zsh -ic '
    alias | LC_ALL=C /usr/bin/sort
  ' 2>/dev/null | while IFS= read -r line; do
    local alias_name="" alias_value=""
    alias_name=${line%%=*}
    alias_value=${line#*=}
    alias_value=${alias_value#\'}
    alias_value=${alias_value%\'}
    printf '| `%s` | `%s` |\n' "$alias_name" "$alias_value"
  done
}

emit_function_rows() {
  /bin/cat <<'EOF'
| Function | Purpose |
| --- | --- |
| `ta` | attach to tmux session `main` or create it |
| `tn` | create a new tmux session |
| `mux` | wrapper around `ta` |
| `blr` | rerun the latest saved terminal-block command |
| `terminal_hints_widget` | zle widget bound to `Ctrl-G` and `Esc-g` |
| `switch_theme` | interactive Ghostty theme switcher |
EOF
}

emit_local_scripts() {
  local dir="$HOME/.local/bin"
  [[ -d "$dir" ]] || return 0
  /usr/bin/find "$dir" -maxdepth 1 -type f -perm -111 -print 2>/dev/null |
    LC_ALL=C /usr/bin/sort |
    while IFS= read -r path; do
      printf -- '- `%s`\n' "${path#$dir/}"
    done
}

{
  /bin/cat <<'EOF'
# CLI Tool Stack

This file is autogenerated by `~/dotfiles/bin/update-cli-tool-stack`.
Do not edit it manually.

## Core Shell Integrations

These are loaded directly into `zsh`:

- `zoxide` via `eval "$(zoxide init zsh)"`
- `atuin` via `eval "$(atuin init zsh)"`
- `starship` via `eval "$(starship init zsh)"`
- `nvm` via `. "$NVM_DIR/nvm.sh"`
- `bun` completions via `. "$HOME/.bun/_bun"`
- `fzf-tab` via `source "/opt/homebrew/opt/fzf-tab/share/fzf-tab/fzf-tab.zsh"`

## Installed CLI Tools

| Tool | Version | Path | Primary Use | Source |
| --- | --- | --- | --- | --- |
EOF

  emit_tool_row tmux "terminal multiplexing / sessions"
  emit_tool_row eza "modern ls replacement"
  emit_tool_row fd "fast file search"
  emit_tool_row btm "system monitor"
  emit_tool_row broot "interactive tree/navigation"
  emit_tool_row yazi "terminal file manager"
  emit_tool_row gitui "terminal Git UI"
  emit_tool_row sk "fuzzy finder / skim"
  emit_tool_row zoxide "smarter directory jumping"
  emit_tool_row atuin "shell history/search/sync"
  emit_tool_row starship "shell prompt"
  emit_tool_row bat "modern cat with formatting"
  emit_tool_row fzf "fuzzy finder"
  emit_tool_row bun "JS runtime / package manager"
  emit_tool_row node "JavaScript runtime"
  emit_tool_row pnpm "package manager"
  emit_tool_row ghostty "terminal emulator CLI hooks"
  emit_tool_row zed "editor CLI launcher"

  /bin/cat <<'EOF'

## Active Aliases

| Alias | Expansion |
| --- | --- |
EOF

  emit_alias_rows

  /bin/cat <<'EOF'

## Shell Functions

EOF

  emit_function_rows

  /bin/cat <<'EOF'

## Local Custom Scripts

These live in `~/.local/bin`:

EOF

  emit_local_scripts

  /bin/cat <<'EOF'

## Notes On Overlap

- `fd`, `broot`, and `yazi` all help with file/directory discovery.
- `fzf` and `sk` are both fuzzy finders.
- `tmux` and Ghostty overlap a bit on workflow ergonomics, but not on core capability.
- `bat` and `eza` are both output enhancers rather than essential tools.
- `node`, `bun`, and `pnpm` overlap in JavaScript workflow territory, though they serve different layers.

## Sensible Pruning Candidates

1. Keep one fuzzy finder: `fzf` or `sk`.
2. Keep one primary file navigator: `yazi` or `broot`.
3. Decide whether you really use the custom `terminal-*` helpers, since they are the most bespoke part of the stack.
4. Keep `nvm` only if you actually switch Node versions; otherwise Homebrew `node` may be enough.
EOF
} >"$TMP_FILE"

/bin/mv "$TMP_FILE" "$OUT_FILE"
